# Para usar con otro proveedor, solo cambiás estas tres líneas:
# Groq:   LLM_BASE_URL=https://api.groq.com/openai/v1   LLM_MODEL=llama3-8b-8192
# Claude: LLM_BASE_URL=https://api.anthropic.com/v1     LLM_MODEL=claude-haiku-4-5-20251001
